# GrantFinder AI — Environment Variables

# Database (set by docker-compose, override for local dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grantfinder
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/grantfinder

# Anthropic (Claude) — per analisi prompt
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — per embeddings semantici
VOYAGE_API_KEY=pa-...

# Modelli (defaults OK per MVP)
CLAUDE_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=voyage-3-lite
